# Copy to .env and fill in real values. Placeholders only — never commit secrets.

NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/market-side
CLIENT_ORIGIN=http://localhost:5173
ADMIN_ORIGIN=http://localhost:5174   # admin console SPA origin (CORS-allowed)
# COOKIE_DOMAIN=.example.com   # prod only: parent domain for auth cookies

JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
# Signs the multi-account switcher cookie (>= 32 chars in production)
MULTI_ACCOUNT_SECRET=change-me-to-a-third-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_ROUNDS=10

# Bootstrap admin — env-configured superadmin login (POST /api/auth/admin/login,
# no captcha). Created on first successful login; env stays the source of truth.
# All three required for admin login to work. Use a strong, unique password.
ADMIN_EMAIL=change-me-to-a-long-unique-email-address
ADMIN_PASSWORD=change-me-to-a-long-unique-password
ADMIN_PHONE=change-me-to-a-long-unique-phone-number

CAPTCHA_TTL_SECONDS=300
CAPTCHA_MAX_ATTEMPTS=5

# Cloudinary (KYC document uploads — private assets, signed delivery)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Price provider (CoinGecko; API key optional on the free tier)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
# Refresh runs 24/7 on this interval — budget it against your provider quota.
# 300s ~= 8.6k calls/month (fits CoinGecko's free 10k); 30s ~= 86k and will
# exhaust a free key in ~3.5 days, breaking deposits/withdrawals/trades.
PRICE_REFRESH_SECONDS=300
TRADE_FEE_PCT=0.1

# Payment gateway (deposits/withdrawals)
PG_BASE_URL=
PG_MERCHANT_ID=
PG_SECRET_KEY=
PG_COUNTRY_CODE=NGN
PG_DEPOSIT_PAYTYPE=NGN_TRANSFER
PG_WITHDRAW_PAYTYPE=NGN_PAYOUT
PG_CALLBACK_BASE_URL=
PG_CALLBACK_IPS=
# This server's public IP, as whitelisted with the gateway. Sent as the `ip`
# submit field; without it the end user's IP goes instead and the gateway
# rejects with 该ip禁止访问 ("IP forbidden"). Must match the whitelist exactly.
PG_SUBMIT_IP=
